# Authlete cluster + service credentials
AUTHLETE_BASE_URL=https://us.authlete.com
AUTHLETE_SERVICE_ID=
AUTHLETE_API_TOKEN=

# AS public origin (the URL RPs use to reach this server)
AS_BASE_URL=http://localhost:3000

# Where the Auth UI lives (default: hosted; override for local auth-ui dev)
AUTH_UI_URL=http://localhost:3001

# Server
PORT=3000
NODE_ENV=development

# CORS allowlist for OAuth endpoints (comma-separated origins).
# Required when browser-based clients like the OAuth Playground call this AS.
# Use "*" only in dev for any origin. Empty (default) disables CORS.
# Example: AS_CORS_ORIGINS=http://localhost:5173,https://playground.example.com
AS_CORS_ORIGINS=
