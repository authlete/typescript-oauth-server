# Authlete cluster + service credentials.
# Find these in the Authlete console (https://console.authlete.com):
# the service ID is shown on your service's page, and the API token is an
# access token you create for that service.
AUTHLETE_BASE_URL=https://us.authlete.com
AUTHLETE_SERVICE_ID=
AUTHLETE_API_TOKEN=

# AS public origin (the URL RPs use to reach this server)
AS_BASE_URL=http://localhost:3000

# Where the Auth UI lives (default: hosted; override for local auth-ui dev)
AUTH_UI_URL=http://localhost:3001

# Server
PORT=3000
NODE_ENV=development

# CORS allowlist for OAuth endpoints (comma-separated origins).
# Required when browser-based clients like the OAuth Playground call this AS.
# Use "*" only in dev for any origin. Empty (default) disables CORS.
# Example: AS_CORS_ORIGINS=http://localhost:5173,https://playground.example.com
AS_CORS_ORIGINS=

# Interaction Protocol (mutual JWT) — see INTERACTION_PROTOCOL.md
# Stable identifiers for issuer/audience claims; default to AS_BASE_URL / AUTH_UI_URL if unset.
AS_ISSUER_ID=
AUTH_UI_ISSUER_ID=
# Where to fetch auth-ui's published JWKS for verifying inbound JWTs.
# Defaults to AUTH_UI_URL/.well-known/jwks.json if unset.
AUTH_UI_JWKS_URI=
# Channel mode: backchannel (server-to-server, production) | frontchannel (dev only)
INTERACTION_CHANNEL=backchannel
# The AS's full private JWKS for signing JWTs to auth-ui. The public half is
# served automatically at /oauth/jwks (merged with the Authlete service keys) —
# no registration with Authlete is needed. Generate one with:
#   node --input-type=module -e "import {generateKeyPair, exportJWK, calculateJwkThumbprint} from 'jose'; const {privateKey} = await generateKeyPair('ES256', {extractable: true}); const jwk = await exportJWK(privateKey); jwk.kid = await calculateJwkThumbprint(jwk); jwk.alg = 'ES256'; console.log(JSON.stringify({keys: [jwk]}))"
AS_SIGNING_JWKS=
# Optional explicit signing-key kid. If unset, resolver picks the only key, then by alg, then first.
AS_SIGNING_KID=
